SceneryThing objRANURA "cerradura ůptica de la puerta"
with
    found_in [;
        if ( location == ZOT_S2___PERSONAL )
                rtrue;
        else    rfalse;
    ],
    name 'RANURA' 'cerradura' 'optica',
    description "Una ranura para llave digital, de manera que sůlo aquellas personas autorizadas puedan entrar a las dependencias de personal. Un pequeŮo piloto de color rojo estŠ encendido.",
    before [;
        Receive:
            if ( noun ~= objLLAVE_DIGITAL_DE_MEMORIA ) {
                "La ranura no es para eso.";
            }
    ],
    react_before [;
        Go:
            if ( noun == in_obj ) {
                <<insert objLLAVE_DIGITAL_DE_MEMORIA>>;
            }
    ],
has female  ;

SceneryThing objTAQUILLA "taquilla" ZOAV_S2___TAQUILLAS
with
    name 'TAQUILLA' 'RANURA' 'CERRADURA' 'OPTICA',
    article 'tu',
    description [;
        print "Tu taquilla tiene tu nombre escrito en una pequeŮa etiqueta",
              " en su frontal. Tiene una cerradura ůptica para tu llave magnťtica.^"
        ;
        if ( self has open ) {
                print "EstŠ abierta.^";
                <<Search self>>;
        }
        else    "EstŠ cerrada.";
    ],
    before [;
        receive:
            if ( noun ~= objLLAVE_DIGITAL_DE_MEMORIA ) {
                "Eso no servirŪa de nada.";
            }
        close:
            if ( self hasnt open ) {
                player.think( "°Que despistado soy!... ya estŠ cerrada." );
                rtrue;
            }

            if ( objLLAVE_DIGITAL_DE_MEMORIA in jugador ) {
                <<insert objLLAVE_DIGITAL_DE_MEMORIA self>>;
            } else "La llave digital de memoria es imprescindible para cerrar la taquilla.";
        open:
            if ( self has open ) {
                player.think( "°Que despistado soy!... ya estŠ abierta." );
                rtrue;
            }

            if ( objLLAVE_DIGITAL_DE_MEMORIA in jugador ) {
                <<insert objLLAVE_DIGITAL_DE_MEMORIA self>>;
            } else "La llave digital de memoria es imprescindible para abrir la taquilla.";
    ],
has female container openable;

