Palanca objPALANCA_MANUAL "palanca manual" ZOMA_S3___CONTROLES
with
    name 'manual',
    description "EstŠ etiquetada como ~apertura de compuertas exteriores~.",
    activate [;
        self.Palanca::activate();
        planificador.ponAdArreglado();
        wait( "..." );

        planificador.ad_statusOk = true;
        print "^Sin embargo, algo te hace pensar que estŠ sucediendo";
        wait( "..." );
        print "^Al principio, no es nada";
        wait( "..." );
        print " Una extraŮa sensaciůn que se va acrecentando";
        wait( "..." );

        if ( objARNES.estaAtado() ) {
            print " Y asŪ, poco a poco, lo notas, tomas conciencia de
                   una vibraciůn que se transmite por la cuerda.
                   Algķn movimiento de gran envergadura,
                   se estŠ produciendo en el Anillo. Instintivamente,
                   giras la cabeza hacia el espacio exterior,
                   y esbozas una gran sonrisa. "
            ;
        } else {
            print " Y asŪ, poco a poco, lo notas, tomas conciencia de
                   una vibraciůn que se transmite por tus miembros en contacto con el DAAD.
                   Algķn movimiento de gran envergadura,
                   se estŠ produciendo en el Anillo. Instintivamente,
                   giras la cabeza hacia el espacio exterior,
                   y esbozas una gran sonrisa. "
            ;
        }
        player.think( "Son las compuertas, °se estŠn abriendo!" );
        wait( "..." );
        print "^Una gran corriente de energŪa recorre tu interior,
               pretendiendo colmar cada hueco, cada miembro, cada mķsculo.^
               Tu mirada parece querer contar cada una de las estrellas que se
               aprecian desde el DAAD.^
               Todo se arreglarŠ ahora, podrŠs salir del Anillo Dorado,
               y ejecutar tu misiůn"
        ;
        wait( "." );
        wait( ".." );

        if ( objARNES.estaAtado() ) {
            print "^^Repentinamente, sientes una nueva vibraciůn en la cuerda";
        } else {
            print "^^Repentinamente, sientes una nueva vibraciůn.
                   Una gran fuerza te expulsa, abruptamente, del DAAD";
        }

        wait( "..." );
        print " Confiado, diriges tu mirada de nuevo a las compuertas exteriores, pero estas
               ya no se mueven"
        ;
        wait( "..." );
        print "^Frunces el ceŮo, y toda tu alegrŪa, transformada en un momento en
               ansiedad, y el mŠs puro miedo, "
        ;

        if ( objARNES.estaAtado() ) {
            objARNES.desataArnes();
            print "se enfoca en la cuerda.^";
        } else {
            print "se enfoca en el vacŪo que te rodea.^";
        }

        wait( "...^^" );
        player.think( "No, por favor. Noooooo..." );
        playSnd1( sndGRITO, 1, SMW_VOLUME_NORMAL );
        player.say( "AAAAAAGGGHHHHH" );

        if ( objARNES.estaAtado() ) {
            print "^La cuerda flota libremente por delante de ti, mientras notas,
                   con un pavor que nunca pensaste que pudieras sentir jamŠs, que estŠs
                   a punto de salir por el compartimento del DAAD.^"
            ;
        } else {
            print "^Tus pies flotan libremente por delante de ti, mientras notas,
                   con un pavor que pensaste que pudieras sentir jamŠs, que estŠs
                   a punto de salir por el compartimento del DAAD.^"
            ;
        }
        wait();
        playSnd1( sndBREATHING, 1, SMW_VOLUME_NORMAL );
        playSnd2( sndHEARTBEAT, 1, SMW_VOLUME_NORMAL );
        player.say( "Mmmppphh, mmmpph, aggh, ah..." );
        print "^Tratas de agarrarte al fuselaje del anillo, aunque todo intento parece en vano";
        wait( "..." );
        print "^^";
        player.think( "No puede terminar asŪ... No puede..." );
        wait( "..." );
        wait( "..." );

        print "^^";
        playerTo( EXTERIOR_DEL_ANILLO, 2 );
        rtrue;
    ],
has ;

