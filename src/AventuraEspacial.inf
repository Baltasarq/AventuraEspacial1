class Palanca
class SceneryThing
with
    name 'palanca' 'etiqueta' 'etiquetado',
    activate [;
        print "La palanca cede, y se mueve, pero, aparentemente, no sucede nada.^";
        rtrue;
    ],
    before [;
        push, pull:
            self.activate();
            rtrue;
    ],
has female;


