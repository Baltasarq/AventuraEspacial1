;

ZOT ZOT_S1___DESCOMPRESION "ZOT S1 - Descompresiůn"
with
    auxGrf grfMapaS1N0,
    cerradura pnjBLOQUEADOR,
    conLlave ZODE_S1___DESCOMPRESION,
    nivel 1,
    description [;
        self.Habitacion::description();
        print "^El ascensor permite acceder a los niveles de descompresiůn y muelles de naves del anillo dorado. Un robot guardiŠn bloqueador vigila el acceso al mismo.^^";
        rtrue;
    ],
    n_to ZOT_S1___DOCUMENTAL,
    s_to ZOT_S4___CAPITANIA,
    u_to [; <<insert objLLAVE_DIGITAL_DE_MEMORIA pnjBLOQUEADOR>>; ],

;
ZOT ZOT_S1___DOCUMENTAL "ZOT S1 - Documental"
with
    auxGrf grfMapaS1N0,
    description [;
        self.Habitacion::description();
        print "^Una amplia entrada conduce a una sala de documentaciůn desde la zona de documentaciůn. Un cartel se sitķa encima del mismo. Hay un holograma en la entrada.^";
        rtrue;
    ],
    n_to ZOT_S2___MANTENIMIENTO,
    s_to ZOT_S1___DESCOMPRESION,
    in_to ZODO_S1___DOCUMENTACION,

;
ZOT ZOT_S2___MANTENIMIENTO "ZOT S2 - Mantenimiento"
with
    auxGrf grfMapaS2N0,
    description [;
        self.Habitacion::description();
        print "^Mantenimiento puede ser accedido desde este pasillo. Por aquŪ suele haber mucho movimiento, personal que necesita hacer comprobaciones de sus llaves digitales o cualquier otro problema con el material o facilidades del anillo dorado.^";
        rtrue;
    ],
    n_to ZOT_S2___PERSONAL,
    s_to ZOT_S1___DOCUMENTAL,
    in_to ZOMA_S2___MANTENIMIENTO,

;
ZOT ZOT_S2___PERSONAL "ZOT S2 - Personal"
with
    auxGrf grfMapaS2N0,
