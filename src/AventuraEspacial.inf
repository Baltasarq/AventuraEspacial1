    description [;
        self.Habitacion::description();
        print "^El hueco es reducido, pero aķn asŪ suficientemente grande para que quepan cuatro personas al mismo tiempo.
		La pared del anillo que deberŪa separar esta estancia del espacio exterior no existe, y, de hecho,
		puedes ver sin dificultad las compuertas de las bahŪas del Anillo Dorado.^Los controles, largo tiempo ya abandonados,
		se esparcen por las paredes del habitŠculo.^";
        rtrue;
    ],
    salidas [;
        print "Puedes ";
        setBeginHyperlink( HL_ARRIBA );
        print (s_fixed) "subir";
        setEndHyperlink();
        print " a los conductos de ventilaciůn, o ";
        setBeginHyperlink( HL_SALIR );
        print (s_fixed) "salir";
        setEndHyperlink();
