[ mueresAsfixiado;
    deadflag = 1;

    print "^...^^Es una sensaciůn mŠs que otra cosa.";
    wait();
    print "^^...^";
    wait();
    print "...^^";
    wait();
    print "Notas como te vas quedando sin aire ... cada vez
           te cuesta mŠs respirar. Te llevas las manos a la garganta, boqueando entre estertores.^";
    print "Te parece que tus ojos se salen de sus ůrbitas, aunque sabes que sůlo te estŠs congelando.",
      " Poco a poco, tu piel toma un color purpķreo.^";
    wait();
    print "Parece que el corazůn se vaya a salir de tu pecho, hasta que se para.^";
    ;
];

