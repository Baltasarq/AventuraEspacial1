Espacio EXTERIOR_DEL_ANILLO "Exterior del anillo"
with
    grfAux Nothing,
    grf picExteriorAD,
    description [;
        self.Habitacion::description();
        print "^Agarrado a un saliente, las compuertas exteriores estŠn exactamente a tu espalda. El resto del inmenso anillo te rodea sobrecogedoramente. El sentimiento de agonŪa y el terrible miedo se acentķan por el hecho de que sůlo puedes oirte a ti mismo respirar entrecortadamente. ^";
        rtrue;
    ],
    salidas [;
        self.Habitacion::salidas();
        "EstŠs muy nervioso, buscas desesperadamente a důnde ir. Tu respiraciůn parece acelerarse por segundos.";
    ],
    cant_go "Sůlo puedes patalear, apenas sabes důnde estŠ cada cosa.",
    before [;
        Examine:
            if ( noun in jugador ) {
                <<Inv>>;
            }
        Inv:
            player.think( "Ahora no voy a apartar la mirada de esta argolla." );
            rtrue;
        gritar:
            player.say( frasesGritar.dev_msg() );
            rtrue;
    ],
;

SceneryThing pared "pared" EXTERIOR_DEL_ANILLO
with
    pegadoPared false,
    name_f 'pared',
    name_fp 'compuertas' 'exteriores',
    name_m 'casco',
    description "La pared del anillo se antoja inmensa desde aquŪ fuera.
                 Justo a tu espalda, se encuentran las compuertas
                exteriores de los hangares, abiertas.",
    before [;
        push, attack:
            if ( ~~self.pegadoPared ) {
                "Te encuentras demasiado lejos de la pared como para empujarla.
                 EstŠs agarrado, eso sŪ, de una argolla.";
            }
            print "Con un fuerte impulso, sales despedido hacia atrŠs, esperando aterrizar en el hangar";
            wait( "..." );
            print " el tiempo parece detenerse";
            wait( "..." );
            print " Los segundos, marcados dolorosamente por los
                  latidos de tu corazůn, que parece querer romper tus sienes,
                  pasan inexorablemente, pero tķ tienes la impresiůn de
                  que nada ha sucedido. Flotas, sŪ, en el vacŪo, y el DAAD
                  se aleja poco a poco de ti, pero...
                  Ņlo conseguirŠs?^"
            ;
            wait( "^..." );
            wait( "...^" );
            playerTo( ZOHA_S1__HANGAR, 2 );
            print "^";
            player.think( "Esto ha estado MUY cerca..." );
            wait();
            print "^";
            print "Apenas te has levantado del suelo, cuando varios pComandos te rodean y te obligan a acompaŮarles";
            wait( "...^" );
            playerTo( ZOT_S1___DESCOMPRESION, 2 );
            print "^Caminas entre ellos, fuertemente escoltado... empiezas a preocuparte... ";
            print "SeguŪs circulando por el pasillo exterior del anillo... ";
            wait();
            print "Hasta llegar a capitanŪa.^";
            wait();
            playerTo( ZOCA_S4___CAPITANIA, 2 );
            pnjCAPITAN.setFinalConversation();
            rtrue;
    ],
has female;

SceneryThing argolla "argolla" EXTERIOR_DEL_ANILLO
with
    name_f 'argolla' 'anilla' 'enganche',
    name_m 'saliente' 'gancho' 'aro',
    description "Una argolla. Es probable que fuera utilizada anteriormente
                para realizar tareas de mantenimiento.",
    before [;
        pull:
            if ( ~~pared.pegadoPared ) {
                pared.pegadoPared = true;
                "Al tirar de la argolla, pegas tu cuerpo a la pared del anillo. Ahora estŠs mŠs tranquilo.";
            } else {
                player.think( "Menos mal..." );
                "Resoplas. Ya estŠs pegado a la pared, lo que te hace estar mŠs tranquilo.";
            }
            rtrue;
        push:
            if ( pared.pegadoPared ) {
                pared.pegadoPared = false;
                print "^Tu respiraciůn se acelera.^";
                player.think( "AsŪ no mejoro las cosas..." );
                print "Te separas de la pared.^";
            } else {
                player.think( "AsŪ me estoy separando de la pared. Mejor no." );
                print "Empiezas a sudar profusamente.^";
            }
            rtrue;
    ]
has female;

