object ControladorTransitoZOT_CAB
with
    found_in [;
        if ( location ofclass ZOT or CAB
          && location ~= ZOT_S1___DESCOMPRESION
          && location ~= ZODE_S1___DESCOMPRESION )
        {
                rtrue;
        } else  rfalse;
    ],
    react_after [;
        Go, Exit:
            if ( ( action == ##Go
                && noun == in_obj or out_obj )
                || action == ##Exit
            )
            {
                if ( location ofclass ZOT )
                        pasar_a_ConexionesAnillo();
                else    pasar_a_ConexionesNauticas();

                playSnd1( sndDOOR, 1, SMW_VOLUME_NORMAL );

                print "Las puertas de la cabina se abren al advertir tu presencia, y se",
                      " cierran tras de ti.^";
            }
    ],
has concealed;

CompassDirection giro_obj "giro" compass
with
    name 'giro' 'g//',
    door_dir n_to
;

CompassDirection antigiro_obj "antigiro" compass
with
    name 'antigiro' 'a//',
    door_dir s_to
;

[ pasar_a_ConexionesAnillo;
    eliminarTodasLasConexiones();

    move giro_obj to compass;
    move antigiro_obj to compass;
    moverConexionesNauticas( compass );
];


class Thing;

class SceneryThing
class Thing
has scenery;

[ hazPresentacion load;
    initializeSMW( 400 );
    viewImageCenter( grfPRESENTA );

    print (s_bold) "La aventura espacial: en el Anillo Dorado (parte I)^";
    print (s_underline) "(revisiůn de la aventura de mismo nombre publicada por Aventuras AD en 1990.)^";
    wait();

    print "ŅDesea cargar una posiciůn anterior? (SŪ/No): ";
    load = yesOrNo();
    buildScreenLayout();

    if ( load ) {
        <<restore>>;
    }
    rtrue;
];

[ buildScreenLayout winMap winInv winExits;
    initializeSMW( 250 );

    winMap   = SMW.createGraphicsWindow( SMW.getMainWindow(), 25, SMW_POS_RIGHT );
    winInv   = SMW.createTextWindow( winMap, 50, SMW_POS_DOWN );
    winExits = SMW.createTextWindow( winInv, 50, SMW_POS_DOWN );
];

[ initialise;
    ! Preparar al jugador
    location = ZOED_S4___AULA;
    move jugador to location;
    changePlayer( jugador );

    ! Preparar el parser
    lookmode = 2;             ! siempre redescribir
    pasar_a_ConexionesAnillo();

    ! Objetos de inventario y otros movimientos
    move objMONO_DE_FAENA to player;
    give objMONO_DE_FAENA worn;
    move objFOTO to player;
    move objLLAVE_DIGITAL_DE_MEMORIA to player;
    move objPDA to objTAQUILLA;
    move pnjSUPERVISOR to objTransmisor;

    ! Preparar personajes y contadores
    startDaemon( Planificador );
    player.prepareAllCharacters();
    laberinto.init();

    ! Empezar
    hazPresentacion();
    Planificador.actualizarVentanas();
];

