    ],
    n_to ZOT_S3___OCIO,
    s_to ZOT_S2___MANTENIMIENTO,
    in_to [; <<insert objLLAVE_DIGITAL_DE_MEMORIA objRANURA>>; ],
;
ZOT ZOT_S3___MIRADOR "ZOT S3 - Mirador"
with
    auxGrf grfMapaS3N0,
    description [;
        self.Habitacion::description();
        print "^El suelo, transparente en esta parte del anillo, se convierte en un amplio mirador espacial. En una pared aparece grabada la inscripciůn ~A.D.~. Una pequeŮa puerta deslizante se encuentra en un lateral.^";
        rtrue;
    ],
    n_to ZOT_S4___INSTRUCCION,
    s_to ZOT_S3___OCIO,
    in_to ZOIN_S3___INGENIERIA,

;
ZOT ZOT_S3___OCIO "ZOT S3 - Ocio"
with
    auxGrf grfMapaS3N0,
    description [;
        self.Habitacion::description();
        print "^De la zona de esparcimiento llegan fuertes risas de comandos de descanso. Sabes que aquellos comandos que han fracasado en su misiůn suelen salir por aquŪ con muy, muy mal aspecto.^";
        rtrue;
    ],
    n_to ZOT_S3___MIRADOR,
    s_to ZOT_S2___PERSONAL,
    in_to ZOES_S3___BAR,

;
ZOT ZOT_S4___CAPITANIA "ZOT S4 - CapitanŪa"
with
    auxGrf grfMapaS4N0,
    description [;
        self.Habitacion::description();
        print "^Pasas frente a las dependencias exclusivas de capitanŪa galŠctica. Desde luego, con tu rango actual, sůlo puedes acudir ahŪ dentro por invitaciůn especŪfica.^";
        if ( self hasnt visited ) {
            print "Siguiendo el ",
                (s_fixed) "giro",
                " del anillo, asŪ como en sentido inverso (",
                (s_fixed) "antigiro",
                "), se extienden los brazos del anillo dorado.^";
            ;
            print "Como en casi todas las zonas de trŠnsito, se puede acceder a una cabina interior.^";
        } else {
            print "Los brazos del anillo continķan en ambos sentidos.^";
        }

        rtrue;
    ],
    n_to ZOT_S1___DESCOMPRESION,
    s_to ZOT_S4___INSTRUCCION,

;
ZOT ZOT_S4___INSTRUCCION "ZOT S4 - Instrucciůn"
with
    auxGrf grfMapaS4N0,
    description [;
        self.Habitacion::description();
        print "^Una entrada permite acceder al aula de instrucciůn, desde esta zona de trŠnsito. Siguiendo el ",
            (s_fixed) "giro",
            " del anillo, asŪ como en sentido inverso (",
            (s_fixed) "antigiro",
            "), se extienden los brazos del anillo dorado.^",
            "Como en casi todas las zonas de trŠnsito, se puede acceder a una cabina interior.^";
        rtrue;
    ],
    n_to ZOT_S4___CAPITANIA,
    s_to ZOT_S3___MIRADOR,
    in_to ZOED_S4___AULA,

;

