object Planificador
with
    ad_statusOk true,    ! true = todo funciona, false = averŪa
    ad_arreglado false,  ! false = no ha pasado nada, true = arreglado.
    ponAdArreglado [;
        self.ad_arreglado = true;
        self.ad_statusOk = true;
    ],
    inicio [;
        ! Trigger the adventure
        print "^";
        wait();
        print "Un robot de mantenimiento se presenta.^";
        wait();
        pnjROBOT_DE_MANTENIMIENTO.say( "AcompŠŮeme. El capitŠn requiere su presencia." );
        player.think( "ŅEl capitŠn galŠctico? °Es increŪble!" );
        print "Tu excitaciůn aumenta por momentos. JamŠs hubieras pensado en algo asŪ, tan pronto. Apenas eres consciente de por důnde vas, te sientes como flotando...^";
        wait();
        playerTo( ZOT_S4___CAPITANIA, 2 );
        print "^Sigues al robot...^";
        wait();
        playerTo( ZOCA_S4___CAPITANIA, 2 );
        print "^El robot no entra, sůlo se asegura de que tķ te estťs frente al capitŠn...^";
        wait();
    ],
    hazInventarioLateral [ x;
        #Ifdef TARGET_GLULX;
                SMW.setCurrentSubWindow( 1 );
                SMW.cleanSubWindow( 1 );

                print (s_emph) "Llevas encima:", "^^";
                objectloop ( x in player ) {
                    print " - ";
                    s_fixed();
                    ! setBeginHyperLink( HL_OBJ_BASE + x );
                    print (name) x;
                    ! setEndHyperlink();
                    s_normal();
                    print "^";
                }
                s_normal();

                SMW.setMainWindowAsCurrent();
        #Ifnot;
            x = 0;
        #Endif;
    ],
    hazMapaLateral [ grfAux;
        #Ifdef TARGET_GLULX;
                grfAux = location.auxGrf;

                if ( grfAux ~= Nothing ) {
                    drawImageInSubWindow( 0, grfAux );
                }
        #Ifnot;
            grfAux = 0;
        #Endif;
    ],
    hazSalidasLateral [;
        #Ifdef TARGET_GLULX;
                SMW.setCurrentSubWindow( 2 );
                SMW.cleanSubWindow( 2 );

                print (s_emph) "Salidas:", "^^";
                <salidas>;

                SMW.setMainWindowAsCurrent();
        #Endif;
    ],
    actualizarInventario [;
        self.hazInventarioLateral();
    ],
    actualizarMapa [;
        self.hazMapaLateral();
        self.actualizaSalidas();
    ],
    actualizaSalidas [;
        self.hazSalidasLateral();
    ],
    actualizarVentanas [;
        self.actualizarInventario();
        self.actualizarMapa();
        self.actualizaSalidas();
    ],
    daemon [;
        if ( turns == 1 ) {
            self.inicio();
            rtrue;
        }
    ],
;

! =============================== GramŠtica ==============================================

[ salidasSub;
    if ( location ofclass ZOT ) {
        print "Los brazos del anillo siguen el sentido del ";
        setBeginHyperlink( HL_GIRO );
        print (s_fixed) "giro";
        setEndHyperLink();
        print " y del ";
        setBeginHyperlink( HL_AGIRO );
        print (s_fixed) "antigiro";
        setEndHyperlink();
        print ". Tambiťn puedes ";
        setBeginHyperlink( HL_ENTRAR );
        print (s_fixed) "entrar";
        setEndHyperlink();
        print " en la cabina.^";
    } else {
        if ( location ofclass CAB ) {
            print "Puedes ";
            setBeginHyperlink( HL_SALIR );
            print (s_fixed) "salir";
            setEndHyperlink();
            print " al pasillo del anillo.^";
        }
        else location.salidas();
    }

    rtrue;
];

[ desatarSub;
    print "No tiene sentido desatar ", (un) noun;

    if ( second ~= Nothing ) {
        print " ", (del) second;
    }

    ".^";
];

[ gritarSub;
    print "EstŠs deseando gritar, pero, lo piensas mejor.^";
    player.think( "Debo tranquilizarme." );
    rtrue;
];

[ayudaSub;
    print "^Las ůrdenes siguientes son bŠsicas y pueden encontrarse
      en casi cualquier aventura conversacional. El jugador
      puede tratar siempre de hacer otras acciones.^^"
    ;
    s_fixed();
    print "^
     ayuda                 -   Esta ayuda.^
     proa, popa, estribor (e), babor (b)
                           -   Moverse en naves segķn puntos nŠuticos.^
     giro (g), antigiro (a)
                           -   Moverse en naves con forma de anillo que rotan.^
     ex, examinar x        -   Da una descripciůn de x.^
     examinarme, xme       -   Informaciůn sobre ti y sobre tu misiůn.^
     hablar con y          -   Permite comunicarse con y, si estŠ presente.^
     coge x, deja x        -   x pasa a ser o deja de ser llevado.^
     i, inventario         -   Da una lista de los objetos llevados.^
     Dar x a y             -   Ofrece el objeto x al personaje y.^
     ^^"
    ;
    s_normal();
    print (s_underline) "Por Baltasar, el Arquero.", (s_normal)
    "^^
      MŠndame tus comentarios a: baltasarq@@64yahoo.es
      ^^
      Tķ eres ", (s_underline) player.short_name,
      ", un Comando Espacial de la Confederaciůn GalŠctica...
     ^";
    <<Examine player>>;
];

[ restartSub;
    L__M( ##Restart,1 );
    if ( YesOrNo() ) {
        closeAllWindows();
        @restart;
        L__M( ##Restart, 2 );
    }
];

[contarSub;
    if ( noun has pluralname ) {
        if ( noun has female )
                "MŠs de una, seguro ...";
        else    "MŠs de uno, seguro ...";
    }
    else {
        if ( noun has female )
                "Una.";
        else    "Uno.";
    }
];

Extend 'cuenta' first
    * noun -> contar
;

Verb 'salidas'
    * -> salidas
;

Verb 'desata'
    * noun -> desatar
    * noun noun -> desatar
    * noun 'de'/'del' noun -> desatar
;

Verb meta 'ayuda' 'pistas'
    * -> ayuda
;
Extend 'grita' first
    * -> gritar
;

Extend 'cuenta' first
    * noun -> contar
    * 'a//'/'al' noun -> contar
;
VerboIrregular "cuenta" with infinitivo "contar";

Extend 'habla' first
    * 'por' noun -> Tell
;

