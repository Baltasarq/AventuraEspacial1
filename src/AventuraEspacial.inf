! AquŪ se produce una conversaciůn entre el capitŠn y el protagonista,
! en la que se le encarga acabar con uno de los detectores de amenazas,
! absolutamente fuera de control.
CAB ZOCA_S4___CAPITANIA "ZOCA S4 - CapitanŪa"
with
    auxGrf grfMapaS4N0,
    grf grfZOCA_S4___CAPITANIA,
    description [;
        self.Habitacion::description();
        print "^Aunque ahora te encuentras en uno de los diversos anexos para reuniones mŠs informales, la sala de capitanŪa es una gran cabina de reuniones donde se deciden cuestiones importantes de la Confederaciůn GalŠctica, asŪ como se planean diferentes misiones.^^";
        rtrue;
    ],
    out_to ZOT_S4___CAPITANIA,

;

Espacio ZODE_S1___CAMARA_ESTANCA "ZODE S1 - CŠmara estanca"
with
    grf grfCADES,
    description [;
        self.Habitacion::description();
        print "^La cŠmara estanca es un pequeŮo lugar de transiciůn con dos puertas. Has entrado por una que ahora estŠ cerrada, y tambiťn estŠ la que se encuentra delante de ti.^";
        rtrue;
    ],
    out_to  ZOHA_S1__HANGAR,
    in_to   ZODE_S1___DESCOMPRESION,
    before [;
        salidas:
            print "Puedes ";
            setBeginHyperlink( HL_SALIR );
            print (s_fixed) "salir";
            setEndHyperlink();
            print " a los hangares, o ";
            setBeginHyperlink( HL_ENTRAR );
            print (s_fixed) "entrar";
            setEndHyperlink();
            print " al anillo, en la zona de descompresiůn.^";
            rtrue;
    ],
;

! [Es un paso a un lugar sin gravedad.]
Room ZODE_S1___DESCOMPRESION "ZODE S1 - Descompresiůn"
with
    grf grfCADES,
    auxGrf grfMapaS1N0,
    nivel 1,
    cerradura objVAINA,
    conLlave objVAINA,
    description [;
        self.Habitacion::description();
        print "^Varias vainas, conteniendo trajes para superar los rigores espaciales, se amontonan en dos de las paredes de esta sala. AsŪ, se puede entrar tambiťn desde aquŪ a la cŠmara estanca, aunque un indicador de color rojo situado en la parte superior de la puerta parece querer disuadirnos de ello. Un transmisor y una base para PDA se sitķan cerca de la compuerta de la cŠmara.^^";
        rtrue;
    ],
    Salidas [;
        print "Puedes ";
        setBeginHyperlink( HL_ARRIBA );
        print (s_fixed) "subir";
        setEndHyperlink();
        print " (a la cŠmara de descompresiůn), o ";
        setBeginHyperlink( HL_ABAJO );
        print (s_fixed) "bajar";
        setEndHyperlink();
        print " (por el ascensor).^";
        rtrue;
    ],
    d_to ZOT_S1___DESCOMPRESION,
    in_to [;
        <<go u_obj>>;
    ],
    u_to [;
        if ( objESCLUSA_DESCOMPRESION.abierta )
                playerTo( ZODE_S1___CAMARA_ESTANCA, 2 );
        else    print "Las compuertas de la cŠmara estanca estŠn cerradas.^";

        rtrue;
    ],
;
Room ZODE_S3___ESCLUSA_ESTANCA "ZODE S3 - Esclusa estanca"
with
    dir introLaberinto,
    auxGrf grfMapaS3N0,
    grf grfCADES,
    description [;
        self.Habitacion::description();
        print "^La pequeŮa esclusa tiene apenas tamaŮo para albergar a una sola persona. Las salidas por encima y por debajo permiten pasar a la zona de control semiautomŠtico del Anillo Dorado. Hay un gancho fijado a la pared. Un botůn rojo bloquea la zona y abre la escotilla de paso.^";
        rtrue;
    ],
	u_to [; self.dir = ZOIN_S3___INGENIERIA; <<push botonDesc>>; ],
	d_to [; self.dir = introLaberinto; <<push botonDesc>>; ],
    before [;
        salidas:
            print "Puedes ";
            setBeginHyperlink( HL_ARRIBA );
            print (s_fixed) "subir";
            setEndHyperlink();
            print " a ingenierŪa, o ";
            setBeginHyperlink( HL_ABAJO );
            print (s_fixed) "bajar";
            setEndHyperlink();
            print " hacia la entrada a las conducciones inferiores.^"
            ;
            rtrue;
    ],
;

SceneryThing botonDesc "botůn de descompresiůn" ZODE_S3___ESCLUSA_ESTANCA
with
    activado false,
    found_in [;
        if ( location == ZODE_S1___CAMARA_ESTANCA
          || location == ZODE_S3___ESCLUSA_ESTANCA )
        {
            rtrue;
        }
        else rfalse;
    ],
	name 'boton' 'rojo' 'descompresion',
	description "Pues eso, un botůn rojo y grande, rodeado de advertencias.",
	before [;
		push:
            if ( ~~self.activado ) {
                print "La cŠmara de descompresiůn no se abre, bloqueando el paso.^";
                print "Vuelves a subir...^";
                playerTo( ZOIN_S3___INGENIERIA, 2 );
                rtrue;
            }

            if ( objARNES.estaAtado()
              && ZODE_S3___ESCLUSA_ESTANCA.dir == ZOIN_S3___INGENIERIA )
            {
                print "Primero desatas la cuerda del gancho.^";
            }

			print "Pulsas el botůn rojo...^";
			print "La compuerta anterior se cierra, y, tras un breve silbido, la posterior se abre, deslizŠndote suavemente...^";

            if ( pnjRATAS in ZODE_S3___ESCLUSA_ESTANCA ) {
                print "El vacŪo hace que las ratas salgan despedidas, y exploten asquerosamente en medio de la estancia.^";
                move objRATAS_MUERTAS to ZODE_S3___ESCLUSA_ESTANCA.dir;
                move pnjRATAS to limbo;
            }

			playerTo( ZODE_S3___ESCLUSA_ESTANCA.dir, 2 );
			rtrue;
	],
;

CAB ZODO_S1___DOCUMENTACION "ZODO S1 - Documentaciůn"
with
    grf grfZODO_S1___DOCUMENTACION,
    auxGrf grfMapaS1N0,
    description [;
        self.Habitacion::description();
        print "^En la suave penumbra que reina en esta zona de documentaciůn, destacan varios nichos para especŪmenes bien iluminados. Albergan todo el conocimiento sobre las muchas otras razas de la confederaciůn galŠctica.^";
        rtrue;
    ],
    out_to ZOT_S1___DOCUMENTAL,

;

! [La confederaciůn galŠctica contra el cerebro loco. Primera parte: en el anillo dorado. Has terminado tu instrucciůn. Eres un comando espacial en misiůn exploratoria.]
CAB ZOED_S4___AULA "ZOED S4 - Aula"
with
    auxGrf grfMapaS4N0,
    grf grfZOED_S4___AULA,
    description [;
        self.Habitacion::description();
        print "^En el aula de instrucciůn toda la atenciůn estŠ centrada alrededor del sabio gran maestro galŠctico, quien, frente al monitor del espacio profundo, instruye a los comandos que no tienen asignada ninguna misiůn.^^";

        if ( self hasnt visited ) {
            player.think( "Por fin. Me he graduado. Ya soy un Comando Espacial." );
            print "^";
        }

        rtrue;
    ],
    out_to ZOT_S4___INSTRUCCION,
;

CAB ZOES_S3___BAR "ZOES S3 - Bar"
with
    grf grfZOES_S3___BAR,
    auxGrf grfMapaS3N0,
    description [;
        self.Habitacion::description();
        print "^Las partŪculas de los cilindros de euforia producen una densa atmůsfera y hacen que la Zona de Esparcimiento estť casi en semipenumbra. Algunos comandos retornados, de otra unidad, celebran su vuelta mientras el ocupado robot de mantenimiento trata de mantener el orden. Los pComandos estŠn, como siempre, por su lado.^^";
        rtrue;
    ],
    out_to ZOT_S3___OCIO,

;
CAB ZOIN_S3___INGENIERIA "ZOIN S3 - IngenierŪa"
with
    auxGrf grfMapaS3N0,
    description [;
        self.Habitacion::description();
        print "^Desde luego, puedes apostar que nunca habŪas estado en este lugar. Se te antoja como si estuvieras viendo en directo las entraŮas del anillo. Lo cierto es que reconoces la tŪpica estructura de una de tantas cabinas de la nave, pero sucia y desaliŮada tambiťn. El hueco de una bajada a una esclusa estanca se percibe en el suelo.^";
        rtrue;
    ],
    before [;
        salidas:
            print "Puedes ";
            setBeginHyperlink( HL_SALIR );
            print (s_fixed) "salir";
            setEndHyperlink();
            print " al pasillo o ";
            setBeginHyperlink( HL_ABAJO );
            print (s_fixed) "bajar";
            setEndHyperlink();
            print " a la esclusa estanca.^";

            rtrue;
    ],
    d_to [;
        ZODE_S3___ESCLUSA_ESTANCA.dir = introLaberinto;
        playerTo( ZODE_S3___ESCLUSA_ESTANCA, 2 );
        rtrue;
    ],
    out_to ZOT_S3___MIRADOR,
;

