SceneryThing objInteriorCabina_false "cabina"
with
    name_f 'cabina',
    name_m 'lugar' 'sitio',
    description [; <<look>>; ],
    found_in [;
        if ( location ofclass CAB )
                rtrue;
        else    rfalse;
    ],
has female;

SceneryThing objCABINA_false "cabina"
with
    name 'cabina',
    before [;
        Enter:
            <<GoIn>>;
    ],
    react_before [;
        Go:
            if ( noun == in_obj
              && location == ZOT_S4___CAPITANIA )
            {
                "Sůlo puedes entrar en capitanŪa por invitaciůn expresa.";
            }
    ],
    description [cab;
        print "Todas las entradas a las cabinas del anillo son iguales, no hay forma de diferenciarlas. Sůlo tu experiencia a bordo te permite hacerlo.^";
        print "El anillo dorado se divide en cuatro sectores, cada uno de ellos tiene dos zonas de trŠnsito como en la que estŠs ahora, permitiendo el paso a una cabina.^";
        cab = location.in_to;

        if ( cab ~= Nothing ) {
            print "Esta cabina es la ";
            s_underline();
            print (name) cab;
            s_normal();
            print ".^";
        } else {
            if ( location == ZOT_S1___DESCOMPRESION ) {
                print "Esta zona de trŠnsito permite acceder a descompresiůn, en los niveles superiores de la nave, asŪ que hay un ascensor en lugar de una cabina.^";
            }
            else
            if ( location == ZOT_S4___CAPITANIA ) {
                print "Sůlo los oficiales tienen acceso a capitanŪa.^";
            }
            else print "No tienes acceso a esta cabina.^";
        }

        rtrue;
    ],
    found_in [;
        if ( location ofclass ZOT )
            rtrue;
        else    rfalse;
    ],
has female;

SceneryThing puertas "puertas"
with
    found_in [;
        if ( location ofclass CAB or ZOT
          && location ~= ZOT_S1___DESCOMPRESION
          && location ~= ZODE_S1___DESCOMPRESION )
        {
            rtrue;
        } else    rfalse;
    ],
    name_f 'puerta' 'compuerta',
    name_fp 'puertas' 'compuertas',
    before [;
        Open, Close:
            "No es necesario. O bien son automŠticas, o bien debe introducirse la llave personal para permitir el paso (si se estŠ autorizado).";
    ],
    description [room;
        if ( location ofclass CAB ) {
            room = location.out_to;
            print (The) self, " permiten el acceso a ";
            if ( room ~= Nothing ) {
                s_underline();
                print (name) room;
                s_normal();
            }
            else print "la zona de trŠnsito";

            print ", con ", (s_fixed) "salir", ".^";
        } else {
            room = location.in_to;
            print (The) self, " permiten el acceso a ";
            if ( room ~= Nothing ) {
                s_underline();
                print (name) room;
                s_normal();
            }
            else print "la cabina";

            print ", con ", (s_fixed) "entrar", ".^";
        }

        rtrue;
    ],
has female pluralname;

Thing objARNES "arnťs" limbo
private
    atado false,
with
    estaAtado [;
        return ( ( self in player ) && self.atado && ( self has worn ) );
    ],
    desataArnes [;
        self.atado = false;
    ],
    name 'ARNES' 'seguridad',
    name_f 'brujula' 'cuerda',
    description [;
        print "El arnťs te lo puedes ceŮir al traje y permite asegurarte
               mediante una larga cuerda. Lleva incorporada una brķjula.^";

        if ( self.estaAtado() ) {
            print "Te has puesto el arnes, y estŠs firmemente sujeto por la cuerda.^";
        }

        print "Te sitķas de manera que la brķjula apunte hacia el norte,
               por delante de ti, y te fijas en las salidas.^";

        <<salidas>>;
    ],
    before [;
        Disrobe:
            if ( self.estaAtado() ) {
                player.think( "No puedo quitarme el arnes estando la cuerda atada..." );
                rtrue;
            }
        Desatar:
            if ( ~~self.estaAtado() ) {
                player.think( "Mmm... la cuerda no estŠ atada a nada." );
                rtrue;
            }

            if ( location ~= ZODE_S3___ESCLUSA_ESTANCA ) {
                player.think( "Mmm... no creo que pueda desatar la cuerda desde aquŪ." );
                rtrue;
            }

            if ( second ~= Nothing
              && second ~= objGANCHO )
            {
                player.think( "La cuerda estŠ atada al gancho." );
                rtrue;
            }

            self.desataArnes();
            "Desatas la cuerda.";
        Tie:
            if ( self.estaAtado() ) {
                player.think( "Mmm... ya estaba atado. Parece que ķltimamente pierdo la memoria." );
                rtrue;
            }

            if ( location == EXTERIOR_DEL_ANILLO ) {
                player.Think( "No pienso separar las manos de este saliente." );
                rtrue;
            }

            if ( location ~= ZODE_S3___ESCLUSA_ESTANCA ) {
                player.Think( "AquŪ no hay donde atar nada." );
                rtrue;
            }

            if ( second == Nothing ) {
                player.think( "Debo decidir a důnde atar la cuerda." );
                rtrue;
            }

            if ( self hasnt worn ) {
                player.think( "De poco me servirŠ atarlo si no me lo pongo primero." );
                rtrue;
            }

            if ( second == objGANCHO ) {
                self.atado = true;
                print "Haces el mejor nudo que sabes.^";
                player.think( "AsŪ deberŪa servir." );
            } else {
                player.think( "No creo que vaya a conseguir nada atŠndo la cuerda ahŪ." );
            }

            rtrue;
    ]
has  clothing;

SceneryThing objASCENSOR "ascensor" ZOT_S1___DESCOMPRESION
with
    name 'ASCENSOR',
    description "El ascensor es un tubo transparente, que de alguna forma, al introducirte en ťl te lleva hasta el otro extremo, sin necesidad de puertas ni nada.",
    before [;
        Bajar:
            if ( location == ZODE_S1___DESCOMPRESION )
                    <<go d_obj>>;
            else    "El ascensor permite ", (s_fixed) "subir", " a niveles superiores.^";
        Enter:
            if ( location == ZOT_S1___DESCOMPRESION )
                    <<go u_obj>>;
            else    <<go d_obj>>;
    ],
    react_after [;
        go:
            if ( noun == d_obj
              || noun == u_obj )
            {
                print "Tras moverse con un pequeŮo suspiro por toda seŮal, las puertas se abren.^";
                rfalse;
            }
    ],
    react_before [;
        GoIn:
            if ( location == ZOT_S1___DESCOMPRESION )
                    <<Enter self>>;
            else    <<salidas>>;

    ],
    found_in [;
        if ( location == ZOT_S1___DESCOMPRESION
          || location == ZODE_S1___DESCOMPRESION )
        {
                rtrue;
        } else  rfalse;
    ],
has   ;

