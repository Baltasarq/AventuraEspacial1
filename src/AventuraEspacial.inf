Thing objLLAVE_DIGITAL_DE_MEMORIA "llave digital de memoria" ZOCA_S4___CAPITANIA
private
    nivel 0,
with
    probada false,
    getNivel [;
        return self.nivel;
    ],
    incrementaNivel [;
        self.nivel++;
        self.probada = false;
        rtrue;
    ],
    name 'LLAVE' 'digital' 'memoria' 'tarjeta',
    description "Es una pequeŮa tarjeta que contiene todos tus datos biomťtricos, asŪ como puede albergar algunos datos sobre tu misiůn, y sobre todo permisos de acceso.",
    before [;
        Insert, PutOn:
                if ( self notin player ) {
                    player.think( "Necesito mi llave de memoria." );
                    rtrue;
                }

                if ( second == Nothing ) {
                    second = location.cerradura;
                }

                self.probada = true;
                if ( objLLAVE_DIGITAL_DE_MEMORIA.nivel >= location.nivel ) {
                    print "Introduces tu llave digital en ", (the) second, ", ",
                        "con lo que el piloto pasa a verde.^"
                    ;

                    if ( location.conLlave == location.cerradura ) {
                        if ( second hasnt open )
                                give second open;
                        else    give second ~open;
                    } else {
                        print "Te pones en movimiento...^";
                        playerTo( location.conLlave, 2 );
                    }
                    rtrue;
                } else {
                    print "Introduces tu llave de memoria en ", (the) second, ".^";
                    wait();
                    print "Sin embargo, no sucede nada. El piloto se mantiene en rojo.^^";
                    wait();
                    player.think( "°Quť extraŮo!... debo ir a mantenimiento a que me arreglen la llave." );
                    rtrue;
                }
        Give:
            if ( second == pnjROBOTS_DE_MANTENIMIENTO ) {
                <<tell pnjROBOTS_DE_MANTENIMIENTO self>>;
            }
            else player.think( "No, mi llave es personal, privada e intrasferible." );
        Show:
            <<give self second>>;
    ],
has female;

SceneryThing objMIRADOR "mirador" ZOT_S3___MIRADOR
with
    name 'MIRADOR',
